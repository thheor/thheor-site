---
import { Moon, SunDim } from "@lucide/astro";

const currentPath = new URL(Astro.request.url).pathname;
let isDark = false;
---

<div class="relative flex justify-center">
  <nav
    id="navbar"
    class="fixed flex justify-center items-center top-5 w-64 sm:w-128 h-8 sm:h-10 transition-all duration-300 ease-in-out border border-ctp-text/20 rounded-xl backdrop-blur-lg shadow-md transparent z-100"
  >
    <button id="open-button" class="sm:hidden">Click to See My Profile🤗</button
    >
    <ul
      id="nav-item"
      class="max-sm:hidden w-full flex max-sm:flex-col my-auto justify-center max-sm:justify-between items-center sm:gap-5 font-medium font-roboto-flex tracking-wide max-md:text-base"
    >
      <li class="max-sm:w-full text-center">
        <a
          href="/"
          class={`block hover:text-ctp-text transition duration-200 ease-in-out ${
            currentPath === "/" ? "text-ctp-text" : "text-ctp-text/70 "
          }`}
        >
          Home
        </a>
      </li>
      <li class="max-sm:w-full text-center">
        <a
          href="/projects"
          class={`block hover:text-ctp-text transition duration-200 ease-in-out ${
            currentPath === "/projects" ? "text-ctp-text" : "text-ctp-text/70 "
          }`}
        >
          What I've done
        </a>
      </li>
      <li class="max-sm:hidden flex items-center">
        <button onclick="" id="modeToggle">
          {isDark ? <SunDim /> : <Moon />}
        </button>
      </li>
      <li class="max-sm:w-full text-center">
        <a
          href="/certifications"
          class={`block hover:text-ctp-text transition duration-200 ease-in-out ${
            currentPath === "/certifications"
              ? "text-ctp-text"
              : "text-ctp-text/70 "
          }`}
        >
          Certifications
        </a>
      </li>
      <li class="max-sm:w-full text-center">
        <a
          href="/blogs"
          class={`block hover:text-ctp-text transition duration-200 ease-in-out ${
            currentPath === "/blogs" ? "text-ctp-text" : "text-ctp-text/70 "
          }`}
        >
          Blogs
        </a>
      </li>
    </ul>
  </nav>
  <button
    id="close-button"
    class="hidden font-roboto-flex sm:hidden fixed top-34 px-5 border border-ctp-text/20 rounded-md shadow-md z-100"
    >Close</button
  >
</div>
<style>
  @keyframes scaleup {
    0% {
      transform: scale(0);
      opacity: 0;
    }
    100% {
      transform: scale(1);
      opacity: 1;
    }
  }

  .animate-scale-up {
    animation: scaleup 0.8s ease-in-out forwards;
  }
</style>
<script>
  const openBtn = document.getElementById("open-button");
  const closeBtn = document.getElementById("close-button");
  const navbarItem = document.getElementById("nav-item");
  const navbar = document.getElementById("navbar") as HTMLElement;

  const openNavbar = () => {
    navbar.classList.remove("items-center", "h-10");
    navbarItem?.classList.toggle("max-sm:hidden");
    openBtn?.classList.toggle("hidden");
    closeBtn?.classList.toggle("hidden");
    navbar.classList.add("items-start", "h-25");
  };

  const closeNavbar = () => {
    navbar.classList.remove("items-start", "h-25");
    navbarItem?.classList.toggle("max-sm:hidden");
    openBtn?.classList.toggle("hidden");
    closeBtn?.classList.toggle("hidden");
    navbar.classList.add("items-center", "h-10");
  };

  openBtn?.addEventListener("click", openNavbar);
  closeBtn?.addEventListener("click", closeNavbar);
</script>

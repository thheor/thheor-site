<div id="container" class="flex justify-center h-screen w-screen">
  <div
    class="flex flex-col justify-center md:items-center w-[80%] sm:w-[60%] mb-10"
  >
    <h1
      class="text-transparent md:-mr-5 flex text-xl 2xl:text-2xl justify-start md:justify-center items-center"
    >
      <span
        id="typewriter"
        class="text-base md:text-xl 2xl:text-2xl text-ctp-text"></span><span
        id="cursor"
        class="bg-ctp-text"></span>h
    </h1>
    <h1
      class="text-4xl md:text-6xl 2xl:text-8xl font-inter font-bold tracking-wide"
    >
      Lukman Prasetyo
    </h1>
    <p
      class="mt-2 text-base leading-7 sm:leading-8 sm:w-[90%] sm:text-center sm:text-xl 2xl:text-2xl font-roboto-flex tracking-wide"
    >
      I'm a computer science student, Web Developer, and Artificial Intelligence
      enthusiast. My passion for web development lies with dreaming up an ideas
      and making them become smart with AI integration.
    </p>
    <a
      href=""
      class="font-roboto-flex font-semibold text-center text-base md:text-base 2xl:text-2xl py-1 sm:py-2 px-6 max-sm:w-50 bg-ctp-text hover:scale-103 transition ease-in-out duration-200 mt-4 text-ctp-base rounded-full"
      >Download Resume</a
    >
  </div>
</div>
<style>
  @keyframes blink {
    0% {
      opacity: 1;
    }
    40% {
      opacity: 1;
    }
    60% {
      opacity: 0;
    }
    100% {
      opacity: 0;
    }
  }
  #cursor {
    display: inline-block;
    width: 1px;
    height: 1.5rem;
    margin-left: 8px;
    opacity: 50;
  }
  #cursor {
    animation: blink 0.8s linear infinite alternate;
  }
</style>
<script>
  const greet = [
    "Hello! my name is",
    "Halo! nama saya",
    "你好，我叫",
    "こんにちは、私の名前は",
  ];

  let i = 0;
  let j = 0;
  let currentWord = "";
  let isDeleting = false;

  const type = () => {
    currentWord = greet[i];
    if (isDeleting) {
      document.getElementById("typewriter").textContent = currentWord.substring(
        0,
        j - 1,
      );
      j--;
      if (j === 0) {
        isDeleting = false;
        i++;
        if (i === greet.length) {
          i = 0;
        }
      }
    } else {
      document.getElementById("typewriter").textContent = currentWord.substring(
        0,
        j + 1,
      );
      j++;
      if (j === currentWord.length) {
        isDeleting = true;
      }
    }
    let timeout = 100;
    if (isDeleting && j === currentWord.length) {
      timeout = 1000;
    } else if (isDeleting) {
      timeout = 60;
    }
    setTimeout(type, timeout);
  };

  type();
</script>

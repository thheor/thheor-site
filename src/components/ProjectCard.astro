---
import ProjectImage from "./ProjectImage.astro";

const { title, date, image, content, path } = Astro.props;
---

<div class="w-full h-full mt-12 sm:mt-15 sm:mb-4">
  <p
    class="font-roboto-flex font-semibold text-xs sm:text-sm 2xl:text-lg tracking-wider"
  >
    {date}
  </p>
  <div class="w-full sm:grid sm:grid-cols-2 mb-4">
    <h1
      class="font-inter font-semibold text-2xl sm:text-3xl xl:text-4xl 2xl:text-5xl tracking-wide"
    >
      {title}
    </h1>
    <div class="flex justify-end items-center">
      <a
        href={path}
        class="font-roboto-flex text-base md:text-lg font-semibold text-center tracking-wide
        max-sm:w-full bg-ctp-text sm:bg-ctp-text/95 sm:px-4 py-1 sm:py-2 max-sm:mt-1
        hover:bg-ctp-text transition ease-in-out duration-100 text-ctp-base rounded-full"
        >See Detail</a
      >
    </div>
  </div>
  <ProjectImage image={image} />
  <p class="border-t-1 border-dashed border-ctp-text/60 mt-5 mb-2"></p>
  <p
    class="text-ctp-text font-roboto-flex italic text-lg xl:text-xl 2xl:text-2xl"
  >
    {content}
  </p>
</div>

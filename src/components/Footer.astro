---
import Github from "@/assets/icons/github.svg";
import Linkedin from "@/assets/icons/linkedin.svg";
import Instagram from "@/assets/icons/instagram.svg";
---

<footer class="w-screen fixed bottom-0 flex justify-center">
  <div class="w-[95%] sm:w-[80%] flex justify-start">
    <div class="flex flex-col justify-center items-center gap-2">
      <a
        href="https://github.com/thheor"
        class="transition duration-300 ease-in-out opacity-100 sm:opacity-60 hover:opacity-100"
      >
        <Github class="w-12 h-12" />
      </a>
      <a
        href="https://www.linkedin.com/in/lukman-prasetyo-341407326/"
        class="transition duration-300 ease-in-out opacity-100 sm:opacity-60 hover:opacity-100"
      >
        <Linkedin class="w-12 h-12" />
      </a>
      <a
        href="https://instagram.com/lukmanp._"
        class="transition duration-300 ease-in-out opacity-100 sm:opacity-60 hover:opacity-100"
      >
        <Instagram class="w-12 h-12" />
      </a>
      <div class="border-l-1 h-25 border-ctp-text/80"></div>
    </div>
  </div>
</footer>

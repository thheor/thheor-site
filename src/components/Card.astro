---
const { title, description } = Astro.props;
---

<div id="card" class="w-100 h-40 bg-ctp-base rounded-lg shadow-xl/30">
  <div class="flex gap-2 mt-2 ml-2">
    <div id="circle" class="rounded-full w-3 h-3 bg-ctp-red"></div>
    <div id="circle" class="rounded-full w-3 h-3 bg-ctp-yellow"></div>
    <div id="circle" class="rounded-full w-3 h-3 bg-ctp-green"></div>
  </div>
  <div id="content" class="ml-2 mt-2">
    <h1 class="text-xl text-ctp-maroon py-2 tracking-tighter">
      Theo <span class="text-base"> / </span><span class="text-ctp-teal"
        >{title}</span
      >
    </h1>
    <p class="text-base">{description}</p>
  </div>
</div>
